---
import type { YoutubeVideo } from '../lib/youtube';

interface Props {
  video: YoutubeVideo;
}

const { video } = Astro.props;
const date = video.publishedAt
  ? new Date(video.publishedAt).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    })
  : '';
---

<a class="vcard surface" href={video.url} target="_blank" rel="noopener noreferrer">
  <div class="vcard__media">
    <img src={video.thumbnailUrl} alt="" width="480" height="270" loading="lazy" />
    <span class="vcard__play" aria-hidden="true">▶</span>
  </div>
  <div class="vcard__body">
    <h3 class="vcard__title">{video.title}</h3>
    {date && <time class="vcard__date" datetime={video.publishedAt}>{date}</time>}
  </div>
</a>

<style>
  .vcard {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition:
      transform 0.15s ease,
      box-shadow 0.15s ease;
  }

  .vcard:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }

  .vcard__media {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #0f172a;
  }

  .vcard__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.95;
  }

  .vcard:hover .vcard__media img {
    opacity: 1;
  }

  .vcard__play {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-size: 2.5rem;
    color: rgba(255, 255, 255, 0.95);
    text-shadow: 0 4px 20px rgba(0, 0, 0, 0.45);
    pointer-events: none;
  }

  .vcard__body {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .vcard__title {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    margin: 0;
    color: var(--color-primary);
    line-height: 1.35;
  }

  .vcard__date {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-weight: var(--font-medium);
  }
</style>
