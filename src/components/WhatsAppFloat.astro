---
const wa = import.meta.env.WA_NUMBER;
const href = `https://wa.me/${wa}`;
---

<a class="wafloat" href={href} target="_blank" rel="noopener noreferrer" aria-label="Chat on WhatsApp">
  <span class="wafloat__pulse" aria-hidden="true"></span>
  <span class="wafloat__pulse wafloat__pulse--2" aria-hidden="true"></span>
  <span class="wafloat__pulse wafloat__pulse--3" aria-hidden="true"></span>
  <span class="wafloat__glow" aria-hidden="true"></span>
  <span class="wafloat__icon" aria-hidden="true">
    <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path
        fill="currentColor"
        d="M16.04 3C9.44 3 4.08 8.36 4.08 14.96c0 2.12.56 4.16 1.62 5.96L4 29l8.28-1.66a12 12 0 0 0 5.76 1.46h.01c6.6 0 11.96-5.36 11.96-11.96C29.99 8.36 24.63 3 18.03 3h-.01Zm-.01 2.4c5.28 0 9.56 4.28 9.56 9.56 0 5.29-4.28 9.57-9.57 9.57a9.45 9.45 0 0 1-4.82-1.32l-.34-.2-4.9.98.99-4.78-.22-.36a9.43 9.43 0 0 1-1.45-5.01c0-5.28 4.28-9.56 9.56-9.56Zm-4.7 4.22c-.25-.01-.58.01-.94.18-.44.2-.75.66-.94 1.1-.45 1.08-.75 2.78.75 4.78 1.5 2 4.34 5.34 9.34 8.34 1.28.74 2.28 1 3.1 1.14.48.08.9.05 1.24-.02.4-.08 1.22-.5 1.4-1 .18-.5.18-.92.12-1.06-.06-.14-.22-.36-.46-.62-.24-.26-1.9-1.86-2.6-2.5-.7-.64-1.22-.54-1.66-.52-.42.02-.9.26-1.38.78-.48.5-1.64 1.6-2 1.8-.36.2-.68.22-.9.02-.44-.4-1.3-1.28-2.04-2.28-.54-.74-.9-1.64-1-1.9-.12-.3.02-.46.14-.6.14-.16.32-.42.48-.64.16-.2.22-.36.34-.6.12-.24.06-.46-.02-.64-.08-.18-.72-1.74-.98-2.38Z"
      ></path>
    </svg>
  </span>
  <span class="wafloat__text">WhatsApp</span>
</a>

<style>
  .wafloat {
    position: fixed;
    right: var(--space-6);
    bottom: var(--space-6);
    z-index: 60;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    border-radius: 999px;
    background: #25d366;
    color: #ffffff;
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    text-decoration: none;
    box-shadow: 0 10px 30px rgba(37, 211, 102, 0.4);
    animation: wafloat-bounce 2s ease-in-out infinite;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .wafloat:hover {
    transform: scale(1.08);
    box-shadow: 0 15px 40px rgba(37, 211, 102, 0.6);
    text-decoration: none;
  }

  .wafloat__icon {
    display: grid;
    place-items: center;
    position: relative;
    z-index: 2;
  }

  .wafloat__text {
    position: relative;
    z-index: 2;
  }

  /* Pulse animation rings */
  .wafloat__pulse {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    border-radius: 999px;
    background: #25d366;
    opacity: 0.8;
    z-index: 1;
    animation: pulse-ring 2.5s ease-out infinite;
  }

  .wafloat__pulse--2 {
    animation-delay: 0.8s;
  }

  .wafloat__pulse--3 {
    animation-delay: 1.6s;
  }

  /* Glow effect behind the button - GPU accelerated */
  .wafloat__glow {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(37, 211, 102, 0.5) 0%, rgba(37, 211, 102, 0) 70%);
    z-index: 0;
    animation: glow-pulse 2s ease-in-out infinite;
    will-change: transform, opacity;
  }

  @keyframes pulse-ring {
    0% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 0.8;
    }
    100% {
      transform: translate(-50%, -50%) scale(1.6);
      opacity: 0;
    }
  }

  @keyframes glow-pulse {
    0%, 100% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 0.6;
    }
    50% {
      transform: translate(-50%, -50%) scale(1.3);
      opacity: 0.9;
    }
  }

  @keyframes wafloat-bounce {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-4px);
    }
  }

  /* Pause bounce on hover */
  .wafloat:hover {
    animation: none;
  }

  /* Mobile: Small circular icon with enhanced pulse */
  @media (max-width: 480px) {
    .wafloat__text {
      display: none;
    }

    .wafloat {
      width: 56px;
      height: 56px;
      padding: 0;
      border-radius: 50%;
      justify-content: center;
      right: var(--space-4);
      bottom: var(--space-4);
      animation: wafloat-bounce-mobile 1.5s ease-in-out infinite;
    }

    .wafloat__icon svg {
      width: 32px;
      height: 32px;
    }

    /* Softer pulse for mobile */
    .wafloat__pulse {
      animation: pulse-ring-mobile 3s ease-out infinite;
    }

    .wafloat__pulse--2 {
      animation-delay: 1s;
    }

    .wafloat__pulse--3 {
      animation-delay: 2s;
    }

    .wafloat__glow {
      animation: glow-pulse-mobile 3s ease-in-out infinite;
      background: radial-gradient(circle, rgba(37, 211, 102, 0.4) 0%, rgba(37, 211, 102, 0) 70%);
    }

    @keyframes pulse-ring-mobile {
      0% {
        transform: translate(-50%, -50%) scale(1);
        opacity: 0.5;
      }
      100% {
        transform: translate(-50%, -50%) scale(2);
        opacity: 0;
      }
    }

    @keyframes glow-pulse-mobile {
      0%, 100% {
        transform: translate(-50%, -50%) scale(1);
        opacity: 0.4;
      }
      50% {
        transform: translate(-50%, -50%) scale(1.5);
        opacity: 0.7;
      }
    }

    @keyframes wafloat-bounce-mobile {
      0%, 100% {
        transform: translateY(0) scale(1);
      }
      50% {
        transform: translateY(-5px) scale(1.02);
      }
    }

    .wafloat:hover {
      transform: scale(1.12);
    }

    .wafloat:hover .wafloat__pulse {
      animation-duration: 1s;
    }
  }
</style>
