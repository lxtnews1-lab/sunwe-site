---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  heroImage?: string;
  ogImage?: string;
  noindex?: boolean;
  schema?: object;
}

const { 
  title, 
  description, 
  canonicalPath, 
  heroImage, 
  ogImage = 'https://wp.sunwevehicle.com/wp-content/uploads/2026/03/hero-scaled.png.webp',
  noindex = false,
  schema
} = Astro.props;

const site = 'https://sunwevehicle.com';
const path = canonicalPath ?? Astro.url.pathname;
const canonical = `${site}${path.startsWith('/') ? path : '/' + path}`;
const fullTitle = title.includes('Sunwe Vehicle') ? title : `${title} | Sunwe Vehicle`;

// Default Organization Schema
const defaultSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Jinan Sunwe Vehicle Co., Ltd.",
  "alternateName": "Sunwe Vehicle",
  "url": site,
  "logo": `${site}/brand/logo-nav.png`,
  "description": "Professional exporter specializing in special trucks and semi trailers with over 13 years of industry experience.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "E39, Building 3, Aosheng Mansion, No. 1166 Xinluo Street, Shunhua Road Sub-district",
    "addressLocality": "Jinan",
    "addressRegion": "Shandong",
    "addressCountry": "CN"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "Sales",
    "availableLanguage": ["English", "Chinese", "Spanish", "Arabic", "French", "Russian"]
  },
  "sameAs": [
    "https://www.youtube.com/@sunwevehicle"
  ]
};

const finalSchema = schema || defaultSchema;
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#1a1f2e" />
    
    <!-- Primary Meta Tags -->
    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />
    <meta name="keywords" content="special trucks, semi trailers, heavy duty trucks, dump trucks, tractor trucks, concrete mixer trucks, crane trucks, fuel tanker trucks, garbage trucks, mining trucks, truck exporter, China trucks, SINOTRUK, HOWO" />
    <meta name="author" content="Jinan Sunwe Vehicle Co., Ltd." />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"} />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonical} />
    
    <!-- Alternate Languages -->
    <link rel="alternate" hreflang="en" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Sunwe Vehicle" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonical} />
    <meta property="twitter:title" content={fullTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />
    
    <!-- Mobile App -->
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Sunwe Vehicle" />
    <meta name="application-name" content="Sunwe Vehicle" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/brand/logo.png" />
    <link rel="apple-touch-icon" href="/brand/logo.png" />
    
    <!-- DNS Prefetch and Preconnect -->
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link rel="dns-prefetch" href="https://wp.sunwevehicle.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://wp.sunwevehicle.com" />
    
    <!-- Preload Critical Resources -->
    <link rel="preload" href="/brand/logo-nav.png" as="image" type="image/png" fetchpriority="high" />
    {heroImage && <link rel="preload" href={heroImage} as="image" fetchpriority="high" />}
    
    <!-- Preload Fonts -->
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" as="style" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    </noscript>
    
    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(finalSchema)} />
    
    <!-- Critical CSS Inline -->
    <style is:inline>
      html { scroll-behavior: smooth; }
      body { 
        margin: 0; 
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        text-rendering: optimizeLegibility;
        -webkit-font-smoothing: antialiased;
      }
      img { 
        max-width: 100%; 
        height: auto; 
        display: block;
      }
      .sw-nav { visibility: visible !important; }
      
      /* Hide Google Translate Toolbar Completely */
      .goog-te-banner-frame,
      .goog-te-banner-frame.skiptranslate,
      .goog-te-menu-frame,
      .goog-te-balloon-frame,
      #goog-gt-tt,
      .goog-tooltip,
      .goog-text-highlight,
      .skiptranslate,
      iframe.goog-te-banner-frame,
      body > .skiptranslate,
      .goog-te-banner,
      .VIpgJd-ZVi9od-aZ2wEe-wOHMyf,
      .VIpgJd-ZVi9od-aZ2wEe-OiiCO,
      .goog-te-combo ~ img,
      .goog-te-gadget-icon,
      .goog-te-gadget-simple img,
      .goog-te-gadget-simple span {
        display: none !important;
        visibility: hidden !important;
        opacity: 0 !important;
        height: 0 !important;
        width: 0 !important;
        border: none !important;
        margin: 0 !important;
        padding: 0 !important;
        position: absolute !important;
        top: -9999px !important;
        left: -9999px !important;
        z-index: -9999 !important;
        pointer-events: none !important;
      }
      
      body { 
        top: 0 !important; 
        position: static !important;
        margin-top: 0 !important;
        padding-top: 0 !important;
      }
      
      html { 
        position: static !important; 
        top: auto !important;
      }
    </style>
  </head>
  <body>
    <slot />
    
    <!-- Google Translate Script (will inject its own element) -->
    <script is:inline>
      function googleTranslateElementInit() {
        // Create container div
        var container = document.createElement('div');
        container.id = 'google_translate_element';
        container.style.cssText = 'position:absolute;top:-9999px;left:-9999px;width:0;height:0;overflow:hidden;opacity:0;';
        document.body.appendChild(container);
        
        // Initialize Google Translate
        new google.translate.TranslateElement({
          pageLanguage: 'en',
          includedLanguages: 'en,zh-CN,es,ar,fr,ru',
          layout: google.translate.TranslateElement.InlineLayout.SIMPLE
        }, 'google_translate_element');
      }
    </script>
    <script is:inline src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
    
    <!-- Disable right-click on images -->
    <script is:inline>
      (function() {
        document.addEventListener('contextmenu', function(e) {
          if (e.target.tagName === 'IMG') {
            e.preventDefault();
            return false;
          }
        });
      })();
    </script>
  </body>
</html>
