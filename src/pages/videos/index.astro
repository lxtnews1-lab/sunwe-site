---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import VideoCard from '../../components/VideoCard.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { getAllPlaylistsWithVideos } from '../../lib/youtube';

const data = await getAllPlaylistsWithVideos().catch(() => [] as Awaited<ReturnType<typeof getAllPlaylistsWithVideos>>);

const title = 'Videos';
const description = 'YouTube playlists: factory tours, model walkarounds, and customer references from Sunwe Vehicle.';

const tabCss = data
  .map(
    (_, i) =>
      `#pl-${i}:checked ~ .tabs__panels .panel-${i}{display:block}#pl-${i}:checked ~ .tabs__labels label[for='pl-${i}']{color:var(--color-primary);border:1px solid var(--color-border-strong);background:#fff;box-shadow:var(--shadow-sm)}`,
  )
  .join('');
---

<BaseLayout title={title} description={description} canonicalPath="/videos">
  <div class="page">
    <Nav />
    <main class="main">
      <div class="container">
        <header class="page-head">
          <h1>Videos</h1>
          <p class="muted">Switch between playlists using the tabs — powered by the YouTube Data API.</p>
        </header>

        {data.length === 0 ? (
          <p class="muted">Videos coming soon.</p>
        ) : (
          <div class="tabs">
            {data.map((_, i) => (
              <input class="tabs__state" type="radio" name="playlist-tab" id={`pl-${i}`} checked={i === 0} />
            ))}

            <div class="tabs__labels" role="tablist" aria-label="Playlist tabs">
              {data.map((block, i) => (
                <label class="tabs__label" for={`pl-${i}`} role="tab">
                  {block.playlist.name}
                </label>
              ))}
            </div>

            <div class="tabs__panels">
              {data.map((block, i) => (
                <section class={`tabs__panel panel-${i}`} role="tabpanel">
                  {block.videos.length === 0 ? (
                    <p class="empty">Videos coming soon</p>
                  ) : (
                    <div class="grid-cards">
                      {block.videos.map((v) => (
                        <VideoCard video={v} />
                      ))}
                    </div>
                  )}
                </section>
              ))}
            </div>
          </div>
        )}
      </div>
    </main>
    <Footer />
    <WhatsAppFloat />
  </div>
</BaseLayout>

<style>
  .page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .main {
    padding-block: var(--space-12);
    flex: 1;
  }

  .page-head {
    margin-bottom: var(--space-8);
  }

  .page-head h1 {
    font-size: var(--text-4xl);
  }

  .tabs {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .tabs__state {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .tabs__labels {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-2);
  }

  .tabs__label {
    cursor: pointer;
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    padding: var(--space-2) var(--space-4);
    border-radius: 999px;
    border: 1px solid transparent;
    color: var(--color-text-muted);
    user-select: none;
  }

  .tabs__label:hover {
    color: var(--color-primary);
    background: rgba(201, 162, 39, 0.12);
  }

  .tabs__panels {
    position: relative;
  }

  .tabs__panel {
    display: none;
  }

  .empty {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }
</style>

<style is:global set:html={tabCss}></style>
