---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { getAllPostSlugs, getPost } from '../../lib/wordpress';

export async function getStaticPaths() {
  const slugs = await getAllPostSlugs().catch(() => [] as string[]);
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const post = slug ? await getPost(slug) : null;

if (!post) {
  return Astro.redirect('/blog');
}

const title = post.title.rendered.replace(/<[^>]+>/g, '');
const description = post.excerpt.rendered.replace(/<[^>]+>/g, '').slice(0, 160);

const date = new Date(post.date);
const dateStr = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const embeddedCats = post._embedded?.['wp:term']?.[0] ?? [];
const catNames = embeddedCats.map((t) => t.name).filter(Boolean);
---

<BaseLayout title={title} description={description} canonicalPath={`/blog/${post.slug}`}>
  <div class="page">
    <Nav />
    <main class="main">
      <div class="container container--narrow">
        <nav class="crumb" aria-label="Breadcrumb">
          <a href="/blog">Blog</a>
          <span aria-hidden="true"> / </span>
          <span>{title}</span>
        </nav>

        <article class="article surface">
          <header class="article__head">
            <p class="article__meta">
              <time datetime={post.date}>{dateStr}</time>
              {catNames.length > 0 && <span> · {catNames.join(', ')}</span>}
            </p>
            <h1>{title}</h1>
          </header>
          <div class="prose-wp article__body" set:html={post.content.rendered} />
        </article>
      </div>
    </main>
    <Footer />
    <WhatsAppFloat />
  </div>
</BaseLayout>

<style>
  .page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .main {
    padding-block: var(--space-12);
    flex: 1;
  }

  .container--narrow {
    max-width: 48rem;
  }

  .crumb {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  .crumb a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: var(--font-medium);
  }

  .crumb a:hover {
    text-decoration: underline;
  }

  .article {
    padding: var(--space-8);
  }

  .article__head {
    margin-bottom: var(--space-8);
  }

  .article__meta {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-4);
  }

  .article__head h1 {
    font-size: var(--text-4xl);
    margin: 0;
  }

  .article__body {
    overflow: auto;
  }
</style>
