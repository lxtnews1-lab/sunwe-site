---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { getAllProducts, getAllProductSlugs } from '../../lib/woocommerce';

// 为所有产品生成静态路径
export async function getStaticPaths() {
  // getAllProductSlugs 返回清理后的 slug 和原始 slug（如果不同）
  const slugs = await getAllProductSlugs().catch(() => []);
  
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;

// 获取所有产品
const allProducts = await getAllProducts().catch(() => []);

// 查找匹配的产品（支持清理后的 slug 和原始 slug）
function findProduct(inputSlug: string) {
  // 首先尝试直接匹配
  let product = allProducts.find(p => p.slug === inputSlug);
  if (product) return product;
  
  // 然后尝试清理输入的 slug 后匹配
  const cleanInput = inputSlug
    .replace(/[³²¹⁴⁵⁶⁷⁸⁹⁰]/g, (c) => {
      const map: Record<string, string> = {
        '³': '3', '²': '2', '¹': '1', '⁴': '4', '⁵': '5',
        '⁶': '6', '⁷': '7', '⁸': '8', '⁹': '9', '⁰': '0'
      };
      return map[c] || c;
    });
  
  product = allProducts.find(p => p.slug === cleanInput);
  if (product) return product;
  
  return null;
}

const product = slug ? findProduct(slug) : null;

// 如果产品不存在，显示 404 页面
if (!product) {
  return new Response(
    `<!DOCTYPE html>
    <html lang="en">
    <head>
      <meta charset="utf-8">
      <meta name="viewport" content="width=device-width, initial-scale=1">
      <title>Product Not Found | Sunwe Vehicle</title>
      <meta name="robots" content="noindex, nofollow">
      <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
          font-family: 'Inter', system-ui, -apple-system, sans-serif;
          background: linear-gradient(135deg, #1a1f2e 0%, #252b3e 100%);
          color: #fff;
          min-height: 100vh;
          display: flex;
          align-items: center;
          justify-content: center;
          padding: 2rem;
        }
        .container { text-align: center; max-width: 480px; }
        .icon { font-size: 4rem; margin-bottom: 1rem; }
        h1 { font-size: 1.75rem; margin-bottom: 1rem; color: #fff; }
        p { color: #d1d5db; margin-bottom: 2rem; line-height: 1.6; }
        .btn {
          display: inline-flex;
          align-items: center;
          gap: 0.5rem;
          padding: 0.85rem 1.5rem;
          background: linear-gradient(90deg, #ff4438, #ff5544);
          color: #fff;
          text-decoration: none;
          border-radius: 999px;
          font-weight: 600;
          font-size: 0.95rem;
          transition: transform 0.2s, box-shadow 0.2s;
        }
        .btn:hover { transform: translateY(-2px); box-shadow: 0 10px 30px rgba(255,68,56,0.3); }
      </style>
    </head>
    <body>
      <div class="container">
        <div class="icon">🔍</div>
        <h1>Product Not Found</h1>
        <p>Sorry, this product has been removed or is no longer available. Please check our product catalog for similar items.</p>
        <a href="/products" class="btn">← Back to Products</a>
      </div>
    </body>
    </html>`,
    {
      status: 404,
      headers: {
        'Content-Type': 'text/html; charset=utf-8',
      },
    }
  );
}

const wa = import.meta.env.WA_NUMBER;
const waText = `Hello, I'm interested in ${product.name}. Please send me more details.`;
const waHref = `https://wa.me/${wa}?text=${encodeURIComponent(waText)}`;

const title = `${product.name} | Special Truck for Export | Sunwe Vehicle`;
const description = product.short_description
  ? product.short_description.replace(/<[^>]+>/g, '').slice(0, 160)
  : `Buy ${product.name} from Sunwe Vehicle. Factory direct, professional customization, global shipping. Contact us for quote!`;

const ogImage = product.images[0]?.src || 'https://wp.sunwevehicle.com/wp-content/uploads/2026/03/hero-scaled.png.webp';

// Product Schema
const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.name,
  "image": product.images.map(img => img.src),
  "description": description,
  "brand": {
    "@type": "Brand",
    "name": "Sunwe Vehicle"
  },
  "manufacturer": {
    "@type": "Organization",
    "name": "Jinan Sunwe Vehicle Co., Ltd."
  },
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "seller": {
      "@type": "Organization",
      "name": "Jinan Sunwe Vehicle Co., Ltd."
    }
  }
};

// Breadcrumb Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://sunwevehicle.com"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Products",
      "item": "https://sunwevehicle.com/products"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": product.name,
      "item": `https://sunwevehicle.com/products/${product.slug}`
    }
  ]
};

const combinedSchema = [productSchema, breadcrumbSchema];

const stripTags = (html: string) => html.replace(/<[^>]+>/g, '').trim();
---

<BaseLayout title={title} description={description} canonicalPath={`/products/${product.slug}`} ogImage={ogImage} schema={combinedSchema}>
  <div class="page">
    <Nav />
    <main class="main">
      <div class="container">
        <nav class="crumb" aria-label="Breadcrumb">
          <a href="/products">Products</a>
          <span aria-hidden="true"> / </span>
          <span>{product.name}</span>
        </nav>

        <div class="layout">
          <div class="gallery surface">
            {product.images.length === 0 ? (
              <div class="gallery__ph" role="img" aria-label={product.name} />
            ) : (
              <div class="gallery__grid">
                {product.images.map((im) => (
                  <figure class="gallery__fig">
                    <Image 
                      src={im.src} 
                      alt={im.alt || product.name} 
                      width={900} 
                      height={600} 
                      quality={85}
                      loading="lazy" 
                      decoding="async"
                    />
                  </figure>
                ))}
              </div>
            )}
          </div>

          <div class="detail">
            <h1>{product.name}</h1>
            {product.short_description ? (
              <div class="short" set:html={product.short_description} />
            ) : null}
            {product.description ? (
              <div class="desc">
                <h2>Description</h2>
                <div class="prose-wp" set:html={product.description} />
              </div>
            ) : null}

            {product.attributes.length > 0 ? (
              <div class="spec surface">
                <h2>Specifications</h2>
                <table class="table-spec">
                  <tbody>
                    {product.attributes
                      .filter((a) => a.visible)
                      .map((a) => (
                        <tr>
                          <th scope="row">{stripTags(a.name)}</th>
                          <td>{a.options.join(', ')}</td>
                        </tr>
                      ))}
                  </tbody>
                </table>
              </div>
            ) : null}

            <div class="cta surface">
              <p class="cta__lead">Request pricing, configuration, and shipping options — we reply on WhatsApp and email.</p>
              <a class="btn btn--whatsapp btn--block" href={waHref} target="_blank" rel="noopener noreferrer">
                WhatsApp inquiry
              </a>
              <a class="btn btn--outline btn--block" href="/contact">Go to contact form</a>
            </div>
          </div>
        </div>
      </div>
    </main>
    <Footer />
    <WhatsAppFloat />
  </div>
</BaseLayout>

<style>
  .page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .main {
    padding-block: var(--space-12);
    flex: 1;
  }

  .crumb {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  .crumb a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: var(--font-medium);
  }

  .crumb a:hover {
    text-decoration: underline;
  }

  .layout {
    display: grid;
    gap: var(--space-10);
    grid-template-columns: 1fr;
  }

  @media (min-width: 960px) {
    .layout {
      grid-template-columns: 1.1fr 0.9fr;
      align-items: start;
    }
  }

  .gallery {
    padding: var(--space-4);
  }

  .gallery__grid {
    display: grid;
    gap: var(--space-4);
  }

  .gallery__fig {
    margin: 0;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: #f8fafc;
  }

  .gallery__fig img {
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .gallery__ph {
    min-height: 280px;
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, #e2e8f0, #cbd5e1);
  }

  .detail h1 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
  }

  .short {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
  }

  .desc h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }

  .spec {
    padding: var(--space-6);
    margin-top: var(--space-8);
  }

  .spec h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-4);
  }

  .cta {
    padding: var(--space-6);
    margin-top: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .cta__lead {
    margin: 0 0 var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
</style>
